# @use ./rts/helpers.rts

### Example end-to-end flow for the running Spring Boot sample
### Assumes:
### 1. the mock server is running on {{base.url}}
### 2. the Spring Boot sample is running on http://127.0.0.1:8081
### 3. the mock server was started with configs/mock-server.springboot.yaml

### Mock server health
# @name MockHealth
GET {{base.url}}/health

### OIDC discovery
# @name Discovery
GET {{base.url}}/.well-known/openid-configuration

### Get a client_credentials access token for the preloaded Spring Boot sample client
# @name Token
POST {{base.url}}/token
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=client_credentials&client_id=springboot-resource-server&scope=openid%20profile%20email

### Call the Spring Boot sample API with the token from the JSON response
### Replace REPLACE_WITH_ACCESS_TOKEN with the access_token returned by Token
# @name SpringApiWithJsonToken
GET http://127.0.0.1:8081/api/me
Authorization: Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiIsImtpZCI6ImtleS1kODM2NzlhNC1iOTU1LTRjOTAtYTRjMi1kODdkNzE2MDAwYzQifQ..Jp0l93975Ki5IqnjFfGefbuE2YZHyz2zkrht6TIbqe3dG2JbsExkRu68x1JdGUn_f5XE3H4m-KvBpb7nSw4vNMBQHs5SsJ0d7kJPYGbyqKv92aNjvls0SiuImRT0TcG80MPh4ReFESXIuA1Va79t9xt9ukqRZPxES-qy9mU1uEI_K8T_rcWj0zcmjOy-gOGBqQBbcEnfVKUeWn_AIxkTZiHXrNg2jdHdvCR63DmROG8vJw2eozdWpOuJVxUfY6wfSU8SIrYpQWNrRHi19wfGzIWeSHmodWStI5ZsCXAE9x-I0Q24vrpsS0fAEV4mOLyPtaEKIKaO5PgJqIcU7wZlVw




### Call the Spring Boot sample API with the Authorization header returned by /token
### Replace REPLACE_WITH_BEARER_HEADER with the full header value from Token, e.g. "Bearer eyJ..."
# @name SpringApiWithHeaderToken
GET http://127.0.0.1:8081/api/me
Authorization: REPLACE_WITH_BEARER_HEADER

### Quick protected API check against the Spring Boot sample
### Replace REPLACE_WITH_BEARER_HEADER with the full header value from Token
# @name SpringApiPing
GET http://127.0.0.1:8081/api/ping
Authorization: REPLACE_WITH_BEARER_HEADER

### Optional: inspect the issued token against the mock server
### Replace REPLACE_WITH_ACCESS_TOKEN with the access_token returned by Token
# @name UserInfo
GET {{base.url}}/userinfo
Authorization: Bearer REPLACE_WITH_ACCESS_TOKEN
